---
import { projectPortfolio } from "@/data/site";
---

<section id="projects" aria-labelledby="projects-heading" class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
  <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">Project portfolio</p>
      <h2 id="projects-heading" class="mt-3 max-w-2xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
        HelioFabric is the flagship. Side projects show range.
      </h2>
      <p class="mt-5 leading-7 text-ink-soft">
        The long-term portfolio is organised around a few reviewed projects: one deep flagship build, public agentic demos, and future standalone tools that are safe to share.
      </p>
    </div>
    <div class="grid gap-4">
      {
        projectPortfolio.map((project) => (
          <article class="rounded-md border border-ink/10 bg-white/70 p-5 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">{project.eyebrow}</p>
                <h3 class="mt-2 font-display text-2xl font-semibold leading-tight text-ink">{project.title}</h3>
              </div>
              <span class="rounded-full border border-ink/12 bg-paper/75 px-3 py-1 text-xs font-semibold uppercase tracking-[0.08em] text-ink-soft">
                {project.status}
              </span>
            </div>
            <p class="mt-4 leading-7 text-ink-soft">{project.summary}</p>
            <p class="mt-4 rounded-md bg-paper-warm/70 p-4 text-sm leading-6 text-ink-soft">
              <strong class="text-ink">Proof signal:</strong> {project.proof}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-full border border-ink/12 bg-white px-3 py-1 text-xs font-semibold text-ink-soft">{tag}</span>
              ))}
            </div>
            <a class="focus-ring mt-5 inline-flex rounded-full bg-ink px-4 py-2.5 text-sm font-semibold text-paper" href={project.href}>
              {project.linkLabel}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
