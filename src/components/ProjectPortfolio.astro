---
import { projectPortfolio } from "@/data/site";
---

<section id="projects" aria-labelledby="projects-heading" class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
  <div class="grid gap-7 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">Project portfolio</p>
      <h2 id="projects-heading" class="mt-3 max-w-2xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
        HelioFabric is the flagship. Side projects show range.
      </h2>
      <p class="mt-5 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
        The long-term portfolio is organised around a few reviewed projects: one deep flagship build, public agentic demos, and future standalone tools that are safe to share.
      </p>
    </div>
    <div class="grid gap-4">
      {
        projectPortfolio.map((project) => (
          <article class="rounded-md border border-ink/10 bg-white/70 p-5 shadow-sm">
            <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">{project.eyebrow}</p>
                <h3 class="mt-2 break-words font-display text-xl font-semibold leading-tight text-ink">{project.title}</h3>
              </div>
              <span class="w-fit max-w-full rounded-md border border-ink/12 bg-paper/75 px-3 py-1 text-xs font-semibold text-ink-soft">
                {project.status}
              </span>
            </div>
            <p class="mt-4 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{project.summary}</p>
            <p class="mt-4 rounded-md bg-paper-warm/70 p-4 text-sm leading-6 text-ink-soft">
              <strong class="text-ink">Proof signal:</strong> {project.proof}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class="rounded-md border border-ink/12 bg-white px-2.5 py-1 text-xs font-semibold text-ink-soft">{tag}</span>
              ))}
            </div>
            <a class="focus-ring mt-5 inline-flex rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-paper" href={project.href}>
              {project.linkLabel}
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
