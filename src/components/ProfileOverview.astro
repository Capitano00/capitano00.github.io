---
import { aboutProfile, capabilitySignals, portfolioLayers } from "@/data/site";
---

<section id="about" aria-labelledby="about-heading" class="mx-auto max-w-7xl px-5 pb-16 sm:px-8">
  <div class="border-y border-ink/12 py-10">
    <div class="grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">{aboutProfile.eyebrow}</p>
        <h2 id="about-heading" class="mt-3 max-w-2xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
          {aboutProfile.heading}
        </h2>
      </div>
      <div class="grid gap-6">
        <div class="grid gap-4 text-base leading-7 text-ink-soft">
          {aboutProfile.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="flex flex-wrap gap-2">
          {
            aboutProfile.focusAreas.map((area) => (
              <span class="rounded-full border border-ink/12 bg-white/70 px-3 py-1.5 text-xs font-semibold text-ink-soft">
                {area}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-3 md:grid-cols-3">
      {
        capabilitySignals.map((signal) => (
          <article class="rounded-md border border-ink/10 bg-white/62 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">{signal.label}</p>
            <h3 class="mt-3 font-display text-xl font-semibold leading-tight text-ink">{signal.title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink-soft">{signal.detail}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-8 grid gap-3 md:grid-cols-3">
      {
        portfolioLayers.map((layer) => (
          <article class="rounded-md border border-ink/10 bg-paper-warm/55 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">{layer.label}</p>
            <h3 class="mt-3 font-display text-xl font-semibold leading-tight text-ink">{layer.title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink-soft">{layer.detail}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
