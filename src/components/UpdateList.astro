---
import { weeklyUpdates } from "@/data/updates";
---

<section id="updates" aria-labelledby="updates-heading" class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
  <div class="grid gap-8 lg:grid-cols-[0.76fr_1.24fr]">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">Public notes</p>
      <h2 id="updates-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
        Project context, captured at a useful level.
      </h2>
      <p class="mt-5 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
        Notes focus on the public shape of the work: what changed, why it matters, and what evidence is safe to show.
      </p>
    </div>
    <div class="border-y border-ink/12">
      {
        weeklyUpdates.map((update) => (
          <article class="py-6">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <p class="text-sm font-semibold text-copper">{update.week}</p>
              <span class="rounded-md border border-ink/15 bg-white/70 px-3 py-1 text-xs font-semibold text-ink-soft">
                {update.status}
              </span>
            </div>
            <h3 class="mt-3 font-display text-xl font-semibold leading-tight text-ink">{update.title}</h3>
            <p class="mt-3 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{update.summary}</p>
            <ul class="mt-4 space-y-2">
              {update.focus.map((item) => (
                <li class="flex gap-3 text-sm leading-6 text-ink-soft">
                  <span class="mt-2 size-1.5 shrink-0 rounded-full bg-copper" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
