---
import { statusCards } from "@/data/site";
---

<section aria-labelledby="status-heading" class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
  <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">Capability snapshot</p>
      <h2 id="status-heading" class="mt-3 max-w-2xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
        Practical strengths, shown through the build.
      </h2>
    </div>
    <p class="max-w-3xl text-base leading-7 text-ink-soft">
      The site keeps the personal profile compact, then uses HelioFabric to demonstrate product thinking, delivery discipline, and responsible automation.
    </p>
  </div>

  <div class="mt-10 divide-y divide-ink/12 border-y border-ink/12">
    {
      statusCards.map((card, index) => (
        <article class="grid gap-3 py-5 md:grid-cols-[5rem_0.55fr_1fr] md:gap-6 md:py-6">
          <p class="font-display text-2xl font-semibold text-copper">{String(index + 1).padStart(2, "0")}</p>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.1em] text-ink-soft">{card.label}</p>
            <h3 class="mt-2 font-display text-2xl font-semibold leading-tight text-ink">{card.value}</h3>
          </div>
          <p class="text-sm leading-6 text-ink-soft md:pt-8">{card.detail}</p>
        </article>
      ))
    }
  </div>
</section>
