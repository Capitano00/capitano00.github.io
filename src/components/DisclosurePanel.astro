---
import { disclosureRules } from "@/data/site";
---

<section aria-labelledby="disclosure-heading" class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
  <div class="grid gap-8 border-y border-copper/25 py-8 md:grid-cols-[0.76fr_1.24fr]">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">Evidence standards</p>
      <h2 id="disclosure-heading" class="mt-3 font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
        The public story stays useful because it stays selective.
      </h2>
      <p class="mt-4 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
        The portfolio explains product thinking and progress without turning private delivery material into public content.
      </p>
    </div>
    <div class="grid gap-3 md:grid-cols-2">
      {
        disclosureRules.map((rule) => (
          <p class="rounded-md border border-ink/10 bg-white/72 px-4 py-3 text-sm leading-6 text-ink-soft">{rule}</p>
        ))
      }
    </div>
  </div>
</section>
