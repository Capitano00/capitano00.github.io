---
import { editorialMetrics, productMapSteps, siteMeta } from "@/data/site";
---

<aside class="w-full min-w-0 max-w-full overflow-hidden rounded-md border border-ink/12 bg-white/88 p-5 shadow-lift backdrop-blur md:p-7" aria-label="HelioFabric product map">
  <div class="flex flex-wrap items-start justify-between gap-4 border-b border-ink/10 pb-5">
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">Public-safe product map</p>
      <h2 class="mt-2 max-w-xl break-words font-display text-2xl font-semibold leading-tight text-ink">
        From repeated workflow pressure to reviewed public progress
      </h2>
    </div>
    <div class="rounded-md border border-ink/10 bg-field/70 px-4 py-3 text-sm leading-6 text-ink-soft">
      <strong class="block text-ink">Publication posture</strong>
      Sanitised signal, not project disclosure.
    </div>
  </div>

  <div class="mt-5 grid gap-3 sm:grid-cols-3">
    {
      editorialMetrics.map((metric) => (
        <div class="rounded-md border border-ink/10 bg-paper px-4 py-3">
          <p class="font-display text-2xl font-semibold text-ink">{metric.value}</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-[0.08em] text-ink-soft">{metric.label}</p>
        </div>
      ))
    }
  </div>

  <ol class="mt-6 grid gap-3">
    {
      productMapSteps.map((step, index) => (
        <li class="group grid min-w-0 grid-cols-[2.25rem_minmax(0,1fr)] gap-3 sm:grid-cols-[2.5rem_minmax(0,1fr)]">
          <div class="flex flex-col items-center">
            <span class="grid size-9 place-items-center rounded-md border border-copper/35 bg-white font-display text-sm font-semibold text-copper shadow-sm">
              {index + 1}
            </span>
            {index < productMapSteps.length - 1 && <span class="mt-2 h-8 w-px bg-ink/18" />}
          </div>
          <div class="min-w-0 border-b border-ink/10 pb-3 transition-colors group-hover:border-copper/35">
            <p class="break-words font-semibold text-ink">{step.label}</p>
            <p class="mt-1 break-words text-sm leading-6 text-ink-soft">{step.detail}</p>
          </div>
        </li>
      ))
    }
  </ol>

  <div class="mt-5 rounded-md border border-copper/20 bg-copper/10 p-4 text-sm leading-6 text-ink-soft">
    <p><strong class="text-ink">Status:</strong> High-level public draft; screenshots require review before Cloudflare upload.</p>
    <p class="mt-2"><strong class="text-ink">Evidence basis:</strong> local Git history inspected on {siteMeta.repositoryEvidence.inspectedOn}.</p>
  </div>
</aside>
