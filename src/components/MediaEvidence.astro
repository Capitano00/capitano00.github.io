---
import { mediaEvidence } from "@/data/media";
---

<section aria-labelledby="media-heading" class="bg-paper-warm/55">
  <div class="mx-auto grid max-w-7xl gap-8 px-5 py-16 sm:px-8 lg:grid-cols-[0.72fr_1.28fr]">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">Visual evidence</p>
      <h2 id="media-heading" class="mt-3 max-w-xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
        Show the product surface without exposing private project material.
      </h2>
      <p class="mt-5 leading-7 text-ink-soft">
        The first public version uses reviewed brand assets and synthetic/redacted product surfaces. Real app screenshots should replace them only after a sandbox-data capture and disclosure review.
      </p>
      <div class="mt-6 rounded-md border border-ink/12 bg-white/70 p-4 text-sm leading-6 text-ink-soft">
        <strong class="block text-ink">Image standard</strong>
        Every visual should explain a product or delivery point, not act as decoration.
      </div>
    </div>
    <div class="grid gap-4">
      {
        mediaEvidence.map((item) => (
          <article class="rounded-md border border-ink/10 bg-white/72 p-4 shadow-sm">
            {item.image && (
              <img
                src={item.image}
                alt={item.alt ?? item.title}
                width="1440"
                height="900"
                decoding="async"
                class="aspect-[16/10] w-full rounded-md border border-ink/10 bg-paper object-contain"
              />
            )}
            <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
              <h3 class="font-display text-2xl font-semibold leading-tight text-ink">{item.title}</h3>
              <span class="rounded-full border border-copper/25 bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.08em] text-copper">
                {item.status.replaceAll("-", " ")}
              </span>
            </div>
            <p class="mt-3 text-sm leading-6 text-ink-soft">{item.intendedUse}</p>
            <p class="mt-3 text-sm leading-6 text-ink-soft">
              <strong class="text-ink">Before publishing:</strong> {item.publicSafetyNote}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
