---
import { flagshipCaseStudy } from "@/data/site";
---

<section id="heliofabric-case-study" aria-labelledby="case-study-heading" class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
  <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">{flagshipCaseStudy.eyebrow}</p>
      <h2 id="case-study-heading" class="mt-3 max-w-2xl font-display text-4xl font-semibold leading-tight text-ink md:text-5xl">
        {flagshipCaseStudy.heading}
      </h2>
      <p class="mt-5 rounded-md border border-copper/25 bg-paper-warm/70 p-4 text-sm leading-6 text-ink-soft">
        <strong class="block text-ink">Publication boundary</strong>
        {flagshipCaseStudy.statusNote}
      </p>
    </div>
    <div class="grid gap-4">
      <article class="rounded-md border border-ink/10 bg-white/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">Problem</p>
        <p class="mt-3 leading-7 text-ink-soft">{flagshipCaseStudy.problem}</p>
      </article>
      <article class="rounded-md border border-ink/10 bg-white/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">Solution</p>
        <p class="mt-3 leading-7 text-ink-soft">{flagshipCaseStudy.solution}</p>
      </article>
    </div>
  </div>

  <div class="mt-8 grid gap-4 lg:grid-cols-2">
    <article class="rounded-md border border-ink/10 bg-white/70 p-5">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-copper">Evidence</p>
      <ul class="mt-4 grid gap-3 text-sm leading-6 text-ink-soft">
        {flagshipCaseStudy.evidence.map((item) => <li class="rounded-md bg-paper/75 px-4 py-3">{item}</li>)}
      </ul>
    </article>
    <article class="rounded-md border border-ink/10 bg-ink p-5 text-paper">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-solar">Safeguards</p>
      <ul class="mt-4 grid gap-3 text-sm leading-6 text-paper/78">
        {flagshipCaseStudy.safeguards.map((item) => <li class="rounded-md border border-paper/12 px-4 py-3">{item}</li>)}
      </ul>
    </article>
  </div>
</section>
