---
import { flagshipCaseStudy } from "@/data/site";

const detailPanels = [
  {
    title: "Implementation evidence",
    intro: "Representative technical evidence, summarised without exposing source code or private data.",
    items: flagshipCaseStudy.evidence
  },
  {
    title: "Delivery method",
    intro: "The working method keeps AI-assisted delivery governed and reviewable.",
    items: flagshipCaseStudy.method
  },
  {
    title: "Publication safeguards",
    intro: "The case study is public only at the level of approved product and workflow evidence.",
    items: flagshipCaseStudy.safeguards
  }
];
---

<section id="heliofabric-case-study" aria-labelledby="case-study-heading" class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
  <div class="grid gap-7 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">{flagshipCaseStudy.eyebrow}</p>
      <h2 id="case-study-heading" class="mt-3 max-w-2xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
        {flagshipCaseStudy.heading}
      </h2>
      <p class="mt-5 rounded-md border border-copper/25 bg-paper-warm/70 p-4 text-sm leading-6 text-ink-soft">
        <strong class="block text-ink">Publication boundary</strong>
        {flagshipCaseStudy.statusNote}
      </p>
    </div>
    <div class="grid gap-4">
      <article class="rounded-md border border-ink/10 bg-white/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">Problem</p>
        <p class="mt-3 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{flagshipCaseStudy.problem}</p>
      </article>
      <article class="rounded-md border border-ink/10 bg-white/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">Solution</p>
        <p class="mt-3 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{flagshipCaseStudy.solution}</p>
      </article>
      <article class="rounded-md border border-ink/10 bg-field/70 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">Proof signal</p>
        <p class="mt-3 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{flagshipCaseStudy.proof}</p>
      </article>
    </div>
  </div>

  <div class="mt-6 grid gap-3">
    {
      detailPanels.map((panel) => (
        <details class="rounded-md border border-ink/10 bg-white/70 shadow-sm">
          <summary class="focus-ring cursor-pointer rounded-md px-5 py-4 font-display text-xl font-semibold leading-tight text-ink">
            {panel.title}
          </summary>
          <div class="border-t border-ink/10 px-5 pb-5 pt-4">
            <p class="max-w-3xl text-sm leading-6 text-ink-soft">{panel.intro}</p>
            <ul class="mt-4 grid gap-2 text-sm leading-6 text-ink-soft md:grid-cols-2">
              {panel.items.map((item) => <li class="rounded-md bg-paper/75 px-4 py-3">{item}</li>)}
            </ul>
          </div>
        </details>
      ))
    }
  </div>
</section>
