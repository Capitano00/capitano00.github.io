---
import { projectAreas } from "@/data/site";
---

<section aria-labelledby="areas-heading" class="bg-ink text-paper">
  <div class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-solar">Delivery system</p>
        <h2 id="areas-heading" class="mt-3 max-w-xl font-display text-4xl font-semibold leading-tight md:text-5xl">
          A governed workflow platform, not a loose demo
        </h2>
        <p class="mt-5 leading-7 text-paper/76">
          The public story should show how the work is organised: data first, tools second, review before publication.
        </p>
      </div>
      <div class="divide-y divide-paper/14 border-y border-paper/14">
        {
          projectAreas.map((area, index) => (
            <article class="grid gap-4 py-6 md:grid-cols-[4rem_1fr]">
              <p class="font-display text-2xl font-semibold text-solar">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="font-display text-2xl font-semibold leading-tight">{area.title}</h3>
                <p class="mt-3 leading-7 text-paper/78">{area.summary}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {area.tags.map((tag) => (
                    <span class="rounded-full border border-paper/15 px-3 py-1 text-xs font-semibold text-paper/80">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
