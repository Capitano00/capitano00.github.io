---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  appliedAISystems,
  atAGlance,
  careerFoundation,
  helioArchitecture,
  heroProfile,
  profileLinks,
  projects,
  technicalBackground
} from "@/data/site";

const sectionNav = [
  { label: "Career", href: "#career" },
  { label: "Applied AI", href: "#applied-ai" },
  { label: "Projects", href: "#projects" },
  { label: "Background", href: "#background" },
  { label: "Profiles", href: "#profiles" }
];
---

<BaseLayout>
  <main id="main">
    <nav aria-label="Section navigation" class="sticky top-0 z-30 border-b border-ink/10 bg-paper/94 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center gap-2 overflow-x-auto px-5 py-2 sm:px-8">
        {
          sectionNav.map((item) => (
            <a class="focus-ring shrink-0 rounded-md px-3 py-2 text-sm font-semibold text-ink-soft hover:bg-white/85 hover:text-ink" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </div>
    </nav>

    <section class="border-b border-ink/10">
      <div class="mx-auto grid max-w-7xl gap-8 px-5 py-10 sm:px-8 lg:grid-cols-[1fr_0.82fr] lg:py-14">
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">
            {heroProfile.eyebrow.map((line) => <span class="block">{line}</span>)}
          </p>
          <h1 class="mt-4 max-w-4xl break-words font-display text-4xl font-semibold leading-[1.03] text-ink sm:text-[3rem] md:text-[3.35rem]">
            {heroProfile.name}
          </h1>
          <p class="mt-4 max-w-2xl text-sm font-semibold leading-6 text-ink-soft sm:text-base sm:leading-7">
            {heroProfile.companyContext}
          </p>
          <p class="mt-5 max-w-3xl break-words font-display text-xl font-semibold leading-tight text-ink sm:text-2xl md:text-[2rem]">
            {heroProfile.headline}
          </p>
          <p class="mt-5 max-w-2xl text-base leading-7 text-ink-soft">
            {heroProfile.summary}
          </p>
          <p class="mt-4 max-w-2xl rounded-md border border-copper/20 bg-white/72 p-4 text-sm font-semibold leading-6 text-ink">
            {heroProfile.judgement}
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a class="focus-ring rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-paper shadow-lift" href={heroProfile.primaryActionHref}>
              {heroProfile.primaryAction}
            </a>
            <a class="focus-ring rounded-md border border-ink/20 bg-white/72 px-4 py-2.5 text-sm font-semibold text-ink" href={heroProfile.secondaryActionHref}>
              {heroProfile.secondaryAction}
            </a>
            <a class="focus-ring rounded-md border border-copper/30 bg-white/72 px-4 py-2.5 text-sm font-semibold text-ink" href={heroProfile.tertiaryActionHref} target="_blank" rel="noreferrer">
              {heroProfile.tertiaryAction}
            </a>
          </div>
        </div>

        <aside aria-labelledby="glance-heading" class="rounded-md border border-ink/10 bg-white/66 p-5 shadow-lift backdrop-blur sm:p-6">
          <h2 id="glance-heading" class="font-display text-2xl font-semibold leading-tight text-ink">
            Executive Summary
          </h2>
          <dl class="mt-6 grid gap-3">
            {
              atAGlance.map((item) => (
                <div class="rounded-md border border-ink/10 bg-paper/72 px-4 py-3">
                  <dt class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">{item.label}</dt>
                  <dd class="mt-1 text-sm font-semibold leading-5 text-ink">{item.value}</dd>
                </div>
              ))
            }
          </dl>
        </aside>
      </div>
    </section>

    <section id="career" aria-labelledby="career-heading" class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
      <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">{careerFoundation.eyebrow}</p>
          <h2 id="career-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
            {careerFoundation.heading}
          </h2>
        </div>
        <p class="max-w-3xl text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
          {careerFoundation.intro}
        </p>
      </div>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {
          careerFoundation.points.map((point) => (
            <article class="rounded-md border border-ink/10 bg-white/70 p-5 shadow-sm">
              <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">{point.label}</p>
              <h3 class="mt-3 font-display text-xl font-semibold leading-tight text-ink">{point.title}</h3>
              <p class="mt-3 text-sm leading-6 text-ink-soft">{point.detail}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="applied-ai" aria-labelledby="applied-ai-heading" class="bg-paper-warm/55">
      <div class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
        <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">{appliedAISystems.eyebrow}</p>
            <h2 id="applied-ai-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
              {appliedAISystems.heading}
            </h2>
          </div>
          <p class="max-w-3xl text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
            {appliedAISystems.intro}
          </p>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {
            appliedAISystems.items.map((item) => (
              <article class="rounded-md border border-ink/10 bg-white/74 p-5 shadow-sm">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">{item.label}</p>
                <h3 class="mt-3 font-display text-xl font-semibold leading-tight text-ink">{item.title}</h3>
                <p class="mt-3 text-sm leading-6 text-ink-soft">{item.detail}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" aria-labelledby="projects-heading" class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
      <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">Side projects</p>
          <h2 id="projects-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
            Projects that turn the workflow pattern into working systems.
          </h2>
        </div>
        <p class="max-w-3xl text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">
          HelioFabric is the flagship project. 3D-RAMS is the public demo that makes the same review-led pattern easier to inspect.
        </p>
      </div>

      <div class="mt-8 grid gap-6">
        {
          projects.map((project) => (
            <article id={project.id} class="rounded-md border border-ink/10 bg-white/72 p-5 shadow-sm sm:p-6">
              <div class="grid gap-6 lg:grid-cols-[0.62fr_1.38fr]">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">{project.eyebrow}</p>
                  {project.image && (
                    <img
                      src={project.image}
                      alt={project.imageAlt ?? project.title}
                      width="1200"
                      height="260"
                      decoding="async"
                      class="mt-5 h-auto w-48 sm:w-56"
                    />
                  )}
                  <h3 class="mt-4 font-display text-2xl font-semibold leading-tight text-ink md:text-3xl">{project.title}</h3>
                  <p class="mt-3 text-lg font-semibold leading-7 text-ink">{project.subtitle}</p>
                  <p class="mt-4 text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{project.summary}</p>
                  <p class="mt-4 inline-flex rounded-md border border-copper/25 bg-paper px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-copper">
                    {project.status}
                  </p>
                  {project.href && (
                    <div class="mt-5">
                      <a class="focus-ring inline-flex rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-paper" href={project.href} target="_blank" rel="noreferrer">
                        {project.linkLabel}
                      </a>
                    </div>
                  )}
                </div>

                <div class="grid gap-4">
                  <div class="grid gap-3 sm:grid-cols-3">
                    {
                      project.metrics.map((metric) => (
                        <div class="rounded-md border border-ink/10 bg-paper/76 p-4">
                          <p class="font-display text-xl font-semibold text-ink">{metric.value}</p>
                          <p class="mt-1 text-xs font-semibold uppercase tracking-[0.08em] text-ink-soft">{metric.label}</p>
                        </div>
                      ))
                    }
                  </div>

                  <div class="grid gap-4 md:grid-cols-3">
                    {
                      project.points.map((point) => (
                        <section class="rounded-md border border-ink/10 bg-white/80 p-4">
                          <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">{point.label}</p>
                          <h4 class="mt-3 font-display text-lg font-semibold leading-tight text-ink">{point.title}</h4>
                          <p class="mt-3 text-sm leading-6 text-ink-soft">{point.detail}</p>
                        </section>
                      ))
                    }
                  </div>

                  {project.id === "heliofabric" && (
                    <section aria-labelledby="architecture-heading" class="rounded-md border border-ink/10 bg-paper/72 p-4">
                      <div class="grid gap-2 sm:grid-cols-[0.65fr_1fr] sm:items-end">
                        <div>
                          <p class="text-xs font-semibold uppercase tracking-[0.1em] text-copper">Architecture</p>
                          <h4 id="architecture-heading" class="mt-2 font-display text-xl font-semibold leading-tight text-ink">
                            From source material to accepted record.
                          </h4>
                        </div>
                        <p class="text-sm leading-6 text-ink-soft">
                          HelioFabric keeps extracted candidates, tool output, and accepted project state separate until review.
                        </p>
                      </div>
                      <ol class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-3" aria-label="HelioFabric architecture flow">
                        {
                          helioArchitecture.map((step, index) => (
                            <li class="rounded-md border border-ink/10 bg-white/80 p-4">
                              <div class="flex items-start gap-3">
                                <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-ink text-xs font-semibold text-paper">
                                  {index + 1}
                                </span>
                                <div>
                                  <p class="text-xs font-semibold uppercase tracking-[0.08em] text-copper">{step.label}</p>
                                  <h5 class="mt-1 font-display text-base font-semibold leading-tight text-ink">{step.title}</h5>
                                  <p class="mt-2 text-sm leading-5 text-ink-soft">{step.detail}</p>
                                </div>
                              </div>
                            </li>
                          ))
                        }
                      </ol>
                    </section>
                  )}

                  <div class="grid gap-3">
                    {
                      project.details.map((panel) => (
                        <details class="rounded-md border border-ink/10 bg-white/80 shadow-sm">
                          <summary class="focus-ring cursor-pointer rounded-md px-4 py-3 font-display text-lg font-semibold leading-tight text-ink">
                            {panel.title}
                          </summary>
                          <ul class="grid gap-2 border-t border-ink/10 px-4 pb-4 pt-3 text-sm leading-6 text-ink-soft md:grid-cols-2">
                            {panel.items.map((item) => <li class="rounded-md bg-paper/75 px-4 py-3">{item}</li>)}
                          </ul>
                        </details>
                      ))
                    }
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section id="background" aria-labelledby="background-heading" class="bg-ink text-paper">
      <div class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
        <div class="grid gap-6 lg:grid-cols-[0.72fr_1.28fr] lg:items-end">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-solar">{technicalBackground.eyebrow}</p>
            <h2 id="background-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight md:text-4xl">
              {technicalBackground.heading}
            </h2>
          </div>
          <p class="max-w-3xl text-sm leading-6 text-paper/76 sm:text-base sm:leading-7">
            {technicalBackground.intro}
          </p>
        </div>
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {
            technicalBackground.items.map((item) => (
              <article class="rounded-md border border-paper/14 bg-paper/5 p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.1em] text-solar">{item.label}</p>
                <h3 class="mt-3 font-display text-xl font-semibold leading-tight">{item.title}</h3>
                <p class="mt-3 text-sm leading-6 text-paper/76">{item.detail}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="profiles" aria-labelledby="profiles-heading" class="mx-auto max-w-7xl px-5 py-12 sm:px-8">
      <div class="grid gap-8 rounded-md border border-ink/10 bg-white/72 p-6 shadow-sm md:grid-cols-[0.8fr_1.2fr] md:p-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-copper">{profileLinks.eyebrow}</p>
          <h2 id="profiles-heading" class="mt-3 max-w-xl font-display text-3xl font-semibold leading-tight text-ink md:text-4xl">
            {profileLinks.heading}
          </h2>
        </div>
        <div class="flex flex-col items-start justify-between gap-5">
          <p class="max-w-2xl text-sm leading-6 text-ink-soft sm:text-base sm:leading-7">{profileLinks.summary}</p>
          <div class="flex flex-wrap gap-3">
            {
              profileLinks.links.map((link) => (
                <a class="focus-ring inline-flex rounded-md bg-ink px-4 py-2.5 text-sm font-semibold text-paper shadow-lift" href={link.href} target="_blank" rel="noreferrer">
                  {link.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
